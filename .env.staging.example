# ⚠️ STAGING ENVIRONMENT — копия для тестового процесса muru-backend-staging (:4001).
# НЕ путать с .env прод-процесса muru-backend. Реальный .env.staging создаётся
# вручную на VPS (этот файл — только шаблон, без секретов).

# Frontend (VITE_* are baked at build time — change on Vercel + redeploy)
VITE_ADMIN_IDS=123456789,987654321
# Dev only. On VPS leave empty — production uses window.location.origin (murushop.ru).
VITE_API_BASE_URL=http://localhost:4000

# Backend (pm2 reload after change). Admin access is checked here; must match real Telegram user IDs.
NODE_ENV=production
PORT=4001
# Staging-домен API, не прод-ориджины (те уже хардкод в index.ts)
ALLOWED_ORIGINS=https://api-staging.murushop.ru
ADMIN_TELEGRAM_IDS=123456789,987654321
ORDER_NOTIFY_TELEGRAM_IDS=123456789,987654321
# ⚠️ ОБЯЗАТЕЛЬНО ПУСТО на staging. Два процесса (прод + staging) с одним и тем же
# токеном одновременно вызывают getUpdates 409 Conflict — прод-бот в Telegram упадёт.
# Staging НЕ тестирует Telegram-поллинг, только HTTP API.
TELEGRAM_BOT_TOKEN=
# Provider token for native Telegram Payments (BotFather → Payments → connect YooKassa test/live).
TELEGRAM_PROVIDER_TOKEN=
# HTTPS URL of the Mini App (for web_app buttons in the bot menu — not t.me/...)
# Must include /catalog path (same as BotFather menu button), not site root only
TELEGRAM_MINI_APP_URL=https://murushop.ru/catalog
# Bot profile before START (backend calls setMyDescription on startup)
BOT_WELCOME_DESCRIPTION=Добро пожаловать в магазин интерьерного декора MURU
# Caption after /start (optional; multiline supported)
# BOT_WELCOME_MESSAGE=
# External inline buttons (url type)
BOT_SITE_URL=https://muru.ru
BOT_CHANNEL_URL=https://t.me/muru_online
BOT_CARE_URL=https://murushop.ru/care
BOT_DELIVERY_URL=https://murushop.ru/delivery
ORDER_NOTIFY_EMAIL=Muru_online@mail.ru

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=mailer@example.com
SMTP_PASS=smtp_password
# Для mail.ru используй:
# SMTP_HOST=smtp.mail.ru
# SMTP_PORT=465
# SMTP_USER=muru_online@mail.ru
# SMTP_PASS=ваш_пароль_приложения (не основной пароль аккаунта!)

# Отдельная БД-копия, НЕ прод-БД
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/muru_staging


GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"
# Catalog ownership: sheets (Google sync, CRM read-only) or crm (CRM writes, sync disabled)
# Legacy: xlsx → sheets ownership + xlsx read mode
CATALOG_SOURCE=sheets
GOOGLE_CATALOG_FILE_ID=13R05JyBIJsMl0fE7qQRxG1nVcKTU3XFg
# Optional: exact worksheet name inside the xlsx file
# GOOGLE_CATALOG_XLSX_SHEET_NAME=
# When catalog ownership is sheets and read mode is Sheets API only
# ENABLE_SHEETS_STOCK_WRITE=true
# Legacy Google Sheet ID (used only when googleCatalogReadMode=sheets)
GOOGLE_SHEET_ID=13oevOsZad_qZ6K8LvCy0Xa-MnALX1dBChS9jMajvaWo
# Root folder: nested catalog photos (Обрезанные / Доп фото) and category covers
GOOGLE_DRIVE_FOLDER_ID=1okABaQzSC-f9H6epKfhMH8sIImE2gLcQ
# On-disk image proxy cache (sharp resized variants)
IMAGE_CACHE_DIR=/var/www/muru/cache/img
# CMS uploaded images (served via nginx /uploads/ in B6)
UPLOADS_DIR=/var/www/muru/uploads
# Сгенерировать НЕЗАВИСИМЫЙ секрет, не копировать прод-JWT_SECRET (staging БД — отдельный снапшот, общие сессии не нужны и не сработают)
JWT_SECRET=generate-random-independent-staging-secret-here
# Секрет для JWT веб-админки (/admin/). ОТДЕЛЬНЫЙ от JWT_SECRET (TG-канал). Обязателен в production (>=32 симв.). Сгенерировать: openssl rand -hex 32
ADMIN_JWT_SECRET=
# Local dev only (single ID). Comma-separated values are not supported.
DEV_TELEGRAM_USER_ID=769499969

# CDEK API v2 (test: api.edu.cdek.ru, prod: api.cdek.ru — separate credentials per environment)
CDEK_ENV=test
CDEK_CLIENT_ID=
CDEK_CLIENT_SECRET=
# Sender pickup (courier from seller address; city code from CDEK directory; 137 = Saint Petersburg)
CDEK_SENDER_CITY_CODE=137
CDEK_SENDER_POSTAL_CODE=192102
CDEK_SENDER_ADDRESS=г. Санкт-Петербург, ул. Дубровская, 13 (цокольный этаж, отдельный вход со двора)
CDEK_SENDER_NAME=
CDEK_SENDER_PHONE=
# Tariff codes for door pickup sender (check: GET /api/cdek/tariff-list?toCityCode=137&weight=3000)
# 139 = дверь→дверь (до двери), 138 = дверь→ПВЗ (до ПВЗ)
CDEK_TARIFF_DOOR=139
CDEK_TARIFF_PVZ=138
# Temporary VPS diagnostics: LOG_CDEK_DEBUG=1 logs [cdek-req]/[cdek-resp] (no auth header)
# LOG_CDEK_DEBUG=1
# Long random string; CDEK webhooks will authenticate with this token
CDEK_WEBHOOK_SECRET=

# DaData address suggestions (https://dadata.ru, free 10k req/day)
# Without DADATA_API_KEY street autocomplete falls back to a free-text input.
DADATA_API_KEY=
# Optional, only needed for standardize endpoints — not used for /address-suggest
DADATA_SECRET_KEY=

# Тестовые (test_...) креды ЮKassa, НЕ прод-ключи. Пусто = платёжные роуты отдают 503, это нормально для staging-смоука без чекаута.
# YooKassa (test secret starts with test_). Empty in dev disables payment endpoints (503).
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Return URL after YooKassa payment (mini app opens PaymentCheckPage on return).
# Test / staging: https://murushop.ru/?pay=check (or full Vercel mini-app URL with ?pay=check)
# Production: https://t.me/<bot_username>/<mini_app_short_name>?startapp=pay (needs start_param=pay in App)
YOOKASSA_RETURN_URL=
# Receipt VAT code: 1 = no VAT
YOOKASSA_VAT_CODE=1
# Webhook IP allowlist (default true). Set false on test/staging if webhooks get 404.
YOOKASSA_VERIFY_IP=false


